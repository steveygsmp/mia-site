{
      "$schema": "https://railway.com/railway.schema.json",
      "build": {
              "builder": "NIXPACKS",
              "nixpacksPlan": {
                        "phases": {
                                    "setup": {
                                                  "nixPkgs": ["python3"]
                                    }
                        }
              }
      },
      "deploy": {
              "startCommand": "python3 -m http.server $PORT",
              "restartPolicyType": "ON_FAILURE"
      }
}
